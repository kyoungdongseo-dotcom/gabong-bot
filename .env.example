# 가봉봇 환경변수 샘플
# 이 파일을 복사해서 .env 로 만든 뒤 실제 값으로 채우세요.
# (.env 는 .gitignore 에 의해 커밋되지 않습니다)

# [필수] 텔레그램 봇 토큰 (BotFather 에서 발급)
TELEGRAM_TOKEN=여기에_실제_토큰_입력

# [선택] 팀 그룹/토픽 ID (기본값: 현재 운영 중인 GAbong Bot 그룹)
GROUP_ID=-1002363981206
TOPIC_ID=2

# [선택] 관리자 텔레그램 user_id (콤마로 여러 명 지정 가능: 123,456)
ADMIN_IDS=97057565

# [선택] 리마인더 데이터 파일 경로
# 로컬: 기본값 사용 (reminders.json)
# Railway: Volume 마운트 경로 지정 (예: /data/reminders.json)
# REMINDERS_FILE=reminders.json
